rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGRAS EXISTENTES (INTEGRAÇÃO COI E SILOS) ---
    match /planejamento_coi/{documentId} { allow read, write: if request.auth != null; }
    match /planejamento_coi_drafts/{userId}/{documentId} { allow read, write: if request.auth != null && request.auth.uid == userId; }
    match /silo_reports/{reportId} { allow read, write: if request.auth != null; }
    match /silo_config/{documentId} { allow read, write: if request.auth != null; }

    // --- REGRAS DO ENSAQUE (ATUALIZADAS PARA PERMITIR DELETE) ---
    match /ensaque_producao/{documentId} { allow read, write: if request.auth != null; }
    match /ensaque_paradas/{documentId} { allow read, write: if request.auth != null; }
    match /ensaque_status_linhas/{lineId} { allow read, write: if request.auth != null; }
    match /ensaque_config/{documentId} { allow read, write: if request.auth != null; }
    match /ensaque_lotes_fechados/{documentId} { allow read, write: if request.auth != null; }

    // --- REGRAS DO SISTEMA DE MOEGA (NOVO) ---
    match /moega_ciclos_ativos/{moegaId} { allow read, write: if request.auth != null; }
    match /moega_historico_descargas/{documentId} { allow read, write: if request.auth != null; }
    match /moega_controle_transferencia/{documentId} { allow read, write: if request.auth != null; }
    match /moega_config/{configId} { allow read, write: if request.auth != null; }

    // --- NOVA REGRA PARA PRÉ-SECAGEM (CORRIGIDA) ---
    // Permite que a interface dashboardPresecagem.html leia os dados publicamente
    // e que a interface presecagem.html (autenticada) escreva nos silos.
    match /mes_silos/{siloId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /mes_secadores/{docId} {
      allow read, write: if true;
    }
    
    match /mes_transferencias/{docId} {
      allow read, write: if true;
    }

    // --- REGRA PARA SINCRONIZADOR DE PARADAS (GOOGLE APPS SCRIPT) ---
    // Permite leitura e escrita por usuários autenticados e por Google Apps Script
    match /paradas_industria/{documentId} { 
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- REGRAS PARA GESTÃO DE SILOS E PERFORMANCE (NOVO) ---
    // Permite leitura e escrita apenas para usuários autenticados
    match /silosQueue/{siloId} {
      allow read, write: if request.auth != null;
    }
    match /beneficiamentoRecords/{recordId} {
      allow read, write: if request.auth != null;
    }

    // --- REGRA PARA A APLICAÇÃO DE GESTÃO DE CONFINAMENTO ---
    // Permite que cada usuário leia e escreva seus próprios dados
    match /gestao_confinamento/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra padrão de bloqueio (Mantenha sempre por último)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
